generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  PROFESSIONAL
  CLIENT
  RECEPTION
}

enum PermissionScope {
  GLOBAL
  TENANT
  SELF
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TimeOffStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum WaitlistStatus {
  WAITING
  OFFERED
  ACCEPTED
  EXPIRED
  CANCELLED
  CONVERTED
}

enum PromotionType {
  SEASONAL
  SERVICE
  PRODUCT
  COMBO
  CART
  CASHBACK
  BIRTHDAY
  REENGAGEMENT
  REFERRAL
}

enum PromotionScope {
  ALL
  CLIENT_SEGMENT
  SERVICE
  SERVICE_CATEGORY
  PRODUCT
  PRODUCT_CATEGORY
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED
  CASHBACK
  FREE_SHIPPING
}

enum BannerPlacement {
  HOME
  HIGHLIGHTS
  CAMPAIGNS
  CHECKOUT
  PROFILE
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  PREPARING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BANK_TRANSFER
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RESERVE
  RELEASE
  RETURN
}

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
  IN_APP
  WHATSAPP
}

enum NotificationStatus {
  DRAFT
  SCHEDULED
  QUEUED
  SENT
  FAILED
  READ
}

enum GalleryMediaType {
  IMAGE
  VIDEO
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoyaltyLevel {
  BRONZE
  SILVER
  GOLD
  DIAMOND
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  REWARDED
  EXPIRED
  CANCELLED
}

enum CommissionRuleType {
  PERCENTAGE
  FIXED
  HYBRID
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum SupportMessageStatus {
  OPEN
  WAITING_CUSTOMER
  WAITING_TEAM
  RESOLVED
  CLOSED
}

enum FileAssetKind {
  IMAGE
  VIDEO
  DOCUMENT
  AVATAR
  BANNER
}

model Tenant {
  id                    String                     @id @default(uuid())
  name                  String
  subdomain             String                     @unique
  locale                String                     @default("pt-BR")
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  deletedAt             DateTime?
  settings              SalonSettings?
  users                 User[]
  roles                 Role[]
  permissions           Permission[]
  adminProfiles         AdminProfile[]
  professionals         Professional[]
  professionalServices  ProfessionalService[]
  workingHours          WorkingHour[]
  timeOffs              TimeOff[]
  clients               Client[]
  serviceCategories     ServiceCategory[]
  services              Service[]
  serviceAddons         ServiceAddon[]
  appointments          Appointment[]
  appointmentServices   AppointmentService[]
  appointmentHistory    AppointmentStatusHistory[]
  waitlistEntries       Waitlist[]
  resources             Resource[]
  transactions          Transaction[]
  commissions           Commission[]
  commissionRules       CommissionRule[]
  loyaltyWallets        LoyaltyWallet[]
  loyaltyTransactions   LoyaltyTransaction[]
  referrals             Referral[]
  campaigns             Campaign[]
  promotions            Promotion[]
  coupons               Coupon[]
  banners               Banner[]
  productCategories     ProductCategory[]
  products              Product[]
  productImages         ProductImage[]
  inventory             Inventory[]
  stockMovements        StockMovement[]
  productFavorites      ProductFavorite[]
  carts                 Cart[]
  cartItems             CartItem[]
  orders                Order[]
  orderItems            OrderItem[]
  payments              Payment[]
  refunds               Refund[]
  notifications         Notification[]
  notificationTemplates NotificationTemplate[]
  deviceTokens          DeviceToken[]
  galleryCategories     GalleryCategory[]
  galleryItems          GalleryItem[]
  reviews               Review[]
  goals                 Goal[]
  goalProgress          GoalProgress[]
  auditLogs             AuditLog[]
  activityLogs          ActivityLog[]
  files                 FileAsset[]
  addresses             Address[]
  supportMessages       SupportMessage[]

  @@index([deletedAt])
}

model User {
  id                      String                     @id @default(uuid())
  email                   String
  phone                   String?
  passwordHash            String
  name                    String
  role                    UserRole
  tenantId                String
  isActive                Boolean                    @default(true)
  emailVerifiedAt         DateTime?
  phoneVerifiedAt         DateTime?
  lastLoginAt             DateTime?
  avatarAssetId           String?
  preferences             Json?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  deletedAt               DateTime?
  tenant                  Tenant                     @relation(fields: [tenantId], references: [id])
  avatarAsset             FileAsset?                 @relation("UserAvatar", fields: [avatarAssetId], references: [id])
  professional            Professional?
  client                  Client?
  adminProfile            AdminProfile?
  roleAssignments         UserRoleAssignment[]
  directPermissions       UserPermission[]
  notifications           Notification[]
  deviceTokens            DeviceToken[]
  auditLogs               AuditLog[]
  activityLogs            ActivityLog[]
  uploadedAssets          FileAsset[]                @relation("FileAssetUploadedBy")
  approvedTimeOffs        TimeOff[]                  @relation("TimeOffApprovedByUser")
  supportMessages         SupportMessage[]           @relation("SupportMessageCreatedByUser")
  assignedSupportMessages SupportMessage[]           @relation("SupportMessageAssignedToUser")
  moderatedReviews        Review[]                   @relation("ReviewModeratedByUser")
  changedStatuses         AppointmentStatusHistory[]
  orders                  Order[]                    @relation("UserOrders")
  carts                   Cart[]                     @relation("UserCarts")
  addresses               Address[]
  refundsCreated          Refund[]                   @relation("RefundCreatedByUser")
  StockMovement           StockMovement[]
  Referral                Referral[]
  refreshTokens           RefreshToken[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId, role])
  @@index([tenantId, isActive])
  @@index([deletedAt])
}

model Role {
  id              String               @id @default(uuid())
  tenantId        String
  name            String
  code            String
  description     String?
  scope           PermissionScope      @default(TENANT)
  isSystem        Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  userAssignments UserRoleAssignment[]

  @@unique([tenantId, code])
  @@index([tenantId, deletedAt])
}

model Permission {
  id              String           @id @default(uuid())
  tenantId        String
  name            String
  code            String
  resource        String
  action          String
  description     String?
  scope           PermissionScope  @default(TENANT)
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@unique([tenantId, code])
  @@index([tenantId, resource, action])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model UserRoleAssignment {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  granted      Boolean    @default(true)
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
}

model AdminProfile {
  id                   String    @id @default(uuid())
  userId               String    @unique
  tenantId             String
  position             String?
  canApproveFinancials Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  user                 User      @relation(fields: [userId], references: [id])
  tenant               Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, deletedAt])
}

model SalonSettings {
  id                         String    @id @default(uuid())
  tenantId                   String    @unique
  salonName                  String
  legalName                  String?
  description                String?
  phone                      String?
  whatsapp                   String?
  email                      String?
  timezone                   String    @default("America/Sao_Paulo")
  currency                   String    @default("BRL")
  locale                     String    @default("pt-BR")
  appointmentLeadTimeMinutes Int       @default(60)
  cancellationWindowHours    Int       @default(24)
  reminderLeadHours          Json?
  allowWaitlist              Boolean   @default(true)
  enableCheckout             Boolean   @default(true)
  enableLoyalty              Boolean   @default(true)
  enableReferrals            Boolean   @default(true)
  enableProductCatalog       Boolean   @default(true)
  primaryColor               String?
  secondaryColor             String?
  accentColor                String?
  instagram                  String?
  facebook                   String?
  tiktok                     String?
  privacyPolicyUrl           String?
  termsAcceptedAt            DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  tenant                     Tenant    @relation(fields: [tenantId], references: [id])
}

model Professional {
  id                 String                @id @default(uuid())
  userId             String                @unique
  tenantId           String
  specialty          String?
  bio                String?
  commissionPercent  Decimal               @default(40.0)
  active             Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deletedAt          DateTime?
  user               User                  @relation(fields: [userId], references: [id])
  tenant             Tenant                @relation(fields: [tenantId], references: [id])
  favoriteByClients  Client[]              @relation("FavoriteProfessional")
  appointments       Appointment[]
  services           ProfessionalService[]
  workingHours       WorkingHour[]
  timeOffs           TimeOff[]
  galleryItems       GalleryItem[]
  waitlistEntries    Waitlist[]            @relation("WaitlistPreferredProfessional")
  transactions       Transaction[]
  commissions        Commission[]
  commissionRules    CommissionRule[]
  goals              Goal[]
  goalProgress       GoalProgress[]
  reviews            Review[]
  AppointmentService AppointmentService[]

  @@index([tenantId, active])
  @@index([deletedAt])
}

model Client {
  id                     String           @id @default(uuid())
  userId                 String           @unique
  tenantId               String
  loyaltyPoints          Int              @default(0)
  lifetimeValue          Decimal          @default(0.0)
  loyaltyLevel           LoyaltyLevel     @default(BRONZE)
  birthDate              DateTime?
  marketingOptIn         Boolean          @default(false)
  favoriteProfessionalId String?
  preferences            Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  deletedAt              DateTime?
  user                   User             @relation(fields: [userId], references: [id])
  tenant                 Tenant           @relation(fields: [tenantId], references: [id])
  favoriteProfessional   Professional?    @relation("FavoriteProfessional", fields: [favoriteProfessionalId], references: [id])
  appointments           Appointment[]
  waitlistEntries        Waitlist[]
  productFavorites       ProductFavorite[]
  carts                  Cart[]
  orders                 Order[]
  loyaltyWallet          LoyaltyWallet?
  addresses              Address[]
  reviews                Review[]
  referralsMade          Referral[]       @relation("ReferralReferrerClient")
  referralsReceived      Referral[]       @relation("ReferralReferredClient")
  supportMessages        SupportMessage[]
  ActivityLog            ActivityLog[]

  @@index([tenantId, loyaltyLevel])
  @@index([favoriteProfessionalId])
  @@index([deletedAt])
}

model ServiceCategory {
  id          String           @id @default(uuid())
  tenantId    String
  name        String
  slug        String
  description String?
  color       String?
  icon        String?
  active      Boolean          @default(true)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  services    Service[]
  rules       CommissionRule[]

  @@unique([tenantId, slug])
  @@index([tenantId, active])
}

model Service {
  id                  String                @id @default(uuid())
  tenantId            String
  categoryId          String?
  name                String
  description         String?
  durationMinutes     Int
  price               Decimal
  bufferBeforeMinutes Int                   @default(0)
  bufferAfterMinutes  Int                   @default(0)
  parallelAllowed     Boolean               @default(false)
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  deletedAt           DateTime?
  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  category            ServiceCategory?      @relation(fields: [categoryId], references: [id])
  addons              ServiceAddon[]
  professionalLinks   ProfessionalService[]
  appointments        Appointment[]
  appointmentServices AppointmentService[]
  galleryItems        GalleryItem[]
  reviews             Review[]
  waitlistEntries     Waitlist[]
  commissionRules     CommissionRule[]

  @@index([tenantId, active])
  @@index([tenantId, categoryId])
  @@index([deletedAt])
}

model ServiceAddon {
  id              String               @id @default(uuid())
  tenantId        String
  serviceId       String
  name            String
  description     String?
  durationMinutes Int                  @default(0)
  price           Decimal              @default(0.0)
  active          Boolean              @default(true)
  sortOrder       Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  service         Service              @relation(fields: [serviceId], references: [id])
  appointmentRows AppointmentService[]

  @@index([tenantId, serviceId, active])
}

model ProfessionalService {
  id                    String       @id @default(uuid())
  tenantId              String
  professionalId        String
  serviceId             String
  customPrice           Decimal?
  customDurationMinutes Int?
  active                Boolean      @default(true)
  sortOrder             Int          @default(0)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  tenant                Tenant       @relation(fields: [tenantId], references: [id])
  professional          Professional @relation(fields: [professionalId], references: [id])
  service               Service      @relation(fields: [serviceId], references: [id])

  @@unique([professionalId, serviceId])
  @@index([tenantId, active])
}

model WorkingHour {
  id                  String        @id @default(uuid())
  tenantId            String
  professionalId      String?
  dayOfWeek           WeekDay
  startTime           String
  endTime             String
  slotIntervalMinutes Int           @default(30)
  active              Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  tenant              Tenant        @relation(fields: [tenantId], references: [id])
  professional        Professional? @relation(fields: [professionalId], references: [id])

  @@index([tenantId, professionalId, dayOfWeek])
}

model TimeOff {
  id               String        @id @default(uuid())
  tenantId         String
  professionalId   String?
  approvedByUserId String?
  title            String
  reason           String?
  startAt          DateTime
  endAt            DateTime
  status           TimeOffStatus @default(APPROVED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  professional     Professional? @relation(fields: [professionalId], references: [id])
  approvedBy       User?         @relation("TimeOffApprovedByUser", fields: [approvedByUserId], references: [id])

  @@index([tenantId, professionalId, startAt, endAt])
}

model Appointment {
  id                  String                     @id @default(uuid())
  tenantId            String
  clientId            String
  professionalId      String
  serviceId           String
  promotionId         String?
  couponId            String?
  status              AppointmentStatus
  scheduledAt         DateTime
  durationMinutes     Int
  price               Decimal
  discount            Decimal                    @default(0.0)
  totalAmount         Decimal
  checkinAt           DateTime?
  startedAt           DateTime?
  finishedAt          DateTime?
  confirmedAt         DateTime?
  cancelledAt         DateTime?
  noShowAt            DateTime?
  followUpSuggestedAt DateTime?
  notes               String?
  internalNotes       String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  deletedAt           DateTime?
  tenant              Tenant                     @relation(fields: [tenantId], references: [id])
  client              Client                     @relation(fields: [clientId], references: [id])
  professional        Professional               @relation(fields: [professionalId], references: [id])
  service             Service                    @relation(fields: [serviceId], references: [id])
  promotion           Promotion?                 @relation(fields: [promotionId], references: [id])
  coupon              Coupon?                    @relation(fields: [couponId], references: [id])
  serviceRows         AppointmentService[]
  statusHistory       AppointmentStatusHistory[]
  waitlistConversions Waitlist[]                 @relation("WaitlistConvertedAppointment")
  resourceBookings    ResourceBooking[]
  transactions        Transaction[]
  payments            Payment[]
  reviews             Review[]
  commissions         Commission[]
  orders              Order[]                    @relation("AppointmentOrders")

  @@index([tenantId, scheduledAt])
  @@index([tenantId, professionalId, scheduledAt])
  @@index([tenantId, clientId, scheduledAt])
  @@index([tenantId, status])
  @@index([deletedAt])
}

model AppointmentService {
  id              String        @id @default(uuid())
  tenantId        String
  appointmentId   String
  serviceId       String
  addonId         String?
  professionalId  String?
  sequence        Int           @default(0)
  durationMinutes Int
  price           Decimal
  discount        Decimal       @default(0.0)
  totalAmount     Decimal
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  appointment     Appointment   @relation(fields: [appointmentId], references: [id])
  service         Service       @relation(fields: [serviceId], references: [id])
  addon           ServiceAddon? @relation(fields: [addonId], references: [id])
  professional    Professional? @relation(fields: [professionalId], references: [id])

  @@index([tenantId, appointmentId, sequence])
}

model AppointmentStatusHistory {
  id              String             @id @default(uuid())
  tenantId        String
  appointmentId   String
  changedByUserId String?
  fromStatus      AppointmentStatus?
  toStatus        AppointmentStatus
  notes           String?
  createdAt       DateTime           @default(now())
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  appointment     Appointment        @relation(fields: [appointmentId], references: [id])
  changedBy       User?              @relation(fields: [changedByUserId], references: [id])

  @@index([tenantId, appointmentId, createdAt])
}

model Waitlist {
  id                      String         @id @default(uuid())
  tenantId                String
  clientId                String
  serviceId               String
  preferredProfessionalId String?
  convertedAppointmentId  String?
  preferredDate           DateTime?
  timeWindowStart         String?
  timeWindowEnd           String?
  status                  WaitlistStatus @default(WAITING)
  notes                   String?
  offeredAt               DateTime?
  respondedAt             DateTime?
  expiresAt               DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  deletedAt               DateTime?
  tenant                  Tenant         @relation(fields: [tenantId], references: [id])
  client                  Client         @relation(fields: [clientId], references: [id])
  service                 Service        @relation(fields: [serviceId], references: [id])
  preferredProfessional   Professional?  @relation("WaitlistPreferredProfessional", fields: [preferredProfessionalId], references: [id])
  convertedAppointment    Appointment?   @relation("WaitlistConvertedAppointment", fields: [convertedAppointmentId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, preferredProfessionalId, preferredDate])
}

model Resource {
  id               String            @id @default(uuid())
  tenantId         String
  type             String
  name             String
  capacity         Int               @default(1)
  active           Boolean           @default(true)
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  resourceBookings ResourceBooking[]

  @@index([tenantId, active])
}

model ResourceBooking {
  id            String      @id @default(uuid())
  appointmentId String
  resourceId    String
  reservedAt    DateTime
  releasedAt    DateTime?
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  resource      Resource    @relation(fields: [resourceId], references: [id])

  @@index([appointmentId, resourceId])
}

model Transaction {
  id             String        @id @default(uuid())
  tenantId       String
  appointmentId  String?
  professionalId String?
  type           String
  category       String
  amount         Decimal
  status         String
  description    String?
  recordedAt     DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id])
  professional   Professional? @relation(fields: [professionalId], references: [id])

  @@index([tenantId, status, recordedAt])
}

model Promotion {
  id           String         @id @default(uuid())
  tenantId     String
  name         String
  slug         String
  description  String?
  type         PromotionType
  scope        PromotionScope @default(ALL)
  active       Boolean        @default(true)
  autoApply    Boolean        @default(false)
  priority     Int            @default(0)
  usageLimit   Int?
  usageCount   Int            @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  criteria     Json?
  benefit      Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  coupons      Coupon[]
  banners      Banner[]
  appointments Appointment[]
  carts        Cart[]
  orders       Order[]

  @@unique([tenantId, slug])
  @@index([tenantId, active, startsAt, endsAt])
}

model Coupon {
  id                String             @id @default(uuid())
  tenantId          String
  promotionId       String?
  code              String
  description       String?
  discountType      CouponDiscountType
  discountValue     Decimal
  minOrderAmount    Decimal?
  maxDiscountAmount Decimal?
  usageLimit        Int?
  usagePerCustomer  Int?
  usageCount        Int                @default(0)
  active            Boolean            @default(true)
  startsAt          DateTime?
  endsAt            DateTime?
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  promotion         Promotion?         @relation(fields: [promotionId], references: [id])
  carts             Cart[]
  orders            Order[]
  appointments      Appointment[]

  @@unique([tenantId, code])
  @@index([tenantId, active])
}

model Banner {
  id                 String          @id @default(uuid())
  tenantId           String
  promotionId        String?
  imageAssetId       String?
  mobileImageAssetId String?
  title              String
  subtitle           String?
  description        String?
  placement          BannerPlacement @default(HOME)
  ctaLabel           String?
  ctaUrl             String?
  active             Boolean         @default(true)
  startsAt           DateTime?
  endsAt             DateTime?
  priority           Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?
  tenant             Tenant          @relation(fields: [tenantId], references: [id])
  promotion          Promotion?      @relation(fields: [promotionId], references: [id])
  imageAsset         FileAsset?      @relation("BannerImage", fields: [imageAssetId], references: [id])
