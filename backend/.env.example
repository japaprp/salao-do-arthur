DATABASE_URL=mysql://root:@127.0.0.1:3306/barbearia_dev
NODE_ENV=development
BACKEND_PORT=3100
PORT=3100
HOST=127.0.0.1
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# JWT / Auth
JWT_SECRET=seu_super_secreto_aleatorio_muito_seguro_aqui
JWT_EXPIRES_IN=1h

# Refresh Token
REFRESH_TOKEN_SECRET=seu_super_secreto_aleatorio_para_refresh_token
REFRESH_TOKEN_EXPIRES_IN=7d

# Recuperação de senha
PASSWORD_RESET_SECRET=seu_super_secreto_aleatorio_para_reset_de_senha
WEB_APP_URL=http://localhost:3001

# Logging
LOG_LEVEL=info
ENABLE_SWAGGER=false

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Firebase Cloud Messaging
# Use uma das opções abaixo em produção/homologação:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=C:\secure\firebase-service-account.json

# Mercado Pago Checkout Pro
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_WEBHOOK_URL=https://api.seudominio.com/api/payments/webhooks/mercado-pago
MERCADO_PAGO_SANDBOX=true
MOBILE_PAYMENT_RETURN_URL=barbeariadoartur://payments/result
