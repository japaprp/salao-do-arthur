# Arquivo de exemplo para produção
# Copie este arquivo para .env.prod e configure as variáveis

# Banco de Dados
DB_NAME=barbearia_do_artur_prod
DB_USER=salao_prod
DB_PASSWORD=mudar_em_producao_segura

# JWT
JWT_SECRET=mudar_em_producao_segura_muito_longa_e_complexa
JWT_EXPIRES_IN=2h
PASSWORD_RESET_SECRET=mudar_em_producao_reset_senha_longo_e_complexo

# Aplicação
BACKEND_PORT=3000
NODE_ENV=production
CORS_ORIGINS=https://seu-frontend.up.railway.app,https://seu-admin.up.railway.app
WEB_APP_URL=https://seu-admin.up.railway.app

# Redis (se usar serviço externo)
REDIS_URL=redis://localhost:6379

# Logs
LOG_LEVEL=info

# Email (futuro)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Storage (futuro)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
